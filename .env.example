# Supabase project credentials — copy this file to .env and fill in the real values.
# Find these in your Supabase dashboard:
#   VITE_SUPABASE_URL      → Settings → Data API → "Project URL"
#   VITE_SUPABASE_ANON_KEY → Settings → API Keys → the row labeled "anon public"
#
# The anon key is safe to expose in frontend code (it's enforced by Row Level
# Security on the database side), but never commit your service_role key —
# that one bypasses RLS and must only live on a trusted backend.
#
# IMPORTANT: The URL must NOT include a trailing slash or /rest/v1/ path.
#   Correct:   https://xxxxx.supabase.co
#   Wrong:     https://xxxxx.supabase.co/
#   Wrong:     https://xxxxx.supabase.co/rest/v1/

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps JavaScript API key — used by the Suppliers page map.
# 1. Go to https://console.cloud.google.com/google/maps-apis/credentials
# 2. Create a new API key (or reuse an existing one)
# 3. Restrict it: Application restrictions → HTTP referrers → add
#      http://localhost:5173/*
#      https://YOUR-VERCEL-DOMAIN.vercel.app/*
#      (plus any custom domain you use)
# 4. API restrictions → "Maps JavaScript API"
# 5. The key is visible in frontend code, which is why the HTTP-referrer
#    restriction is what actually protects you from abuse.
#
# If this is missing the map will render a quiet fallback — the rest of the
# Suppliers page still works normally.

VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
